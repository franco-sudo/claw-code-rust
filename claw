#!/bin/bash

# Claw RS - Quick launcher for GLM model
# This script provides a convenient way to start Claw RS with GLM-4 model

# Get the directory where this script is located (resolve symlinks)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# If script is in /usr/local/bin, use the actual project directory
if [ "$SCRIPT_DIR" = "/usr/local/bin" ]; then
    # Assume project is at /Users/daijingchao/Desktop/claw2/claw-code-rust
    PROJECT_DIR="/Users/daijingchao/Desktop/claw2/claw-code-rust"
else
    PROJECT_DIR="$SCRIPT_DIR"
fi

BINARY_PATH="$PROJECT_DIR/target/release/claw-rs"

# Check if binary exists
if [ ! -f "$BINARY_PATH" ]; then
    echo "❌ Binary not found at $BINARY_PATH"
    echo "Please run: cargo build --release"
    exit 1
fi

# Check if ZHIPU_API_KEY is set
if [ -z "$ZHIPU_API_KEY" ]; then
    # Try to load from config file
    CONFIG_FILE="$HOME/.claw-code-rust/config.json"
    if [ -f "$CONFIG_FILE" ]; then
        echo "✅ Using saved configuration from $CONFIG_FILE"
    else
        echo "⚠️  ZHIPU_API_KEY not set and no saved config found"
        echo "📝 Set it once: export ZHIPU_API_KEY='your_api_key'"
        echo "   Next time it will be auto-saved"
        echo ""
    fi
fi

# Launch Claw RS with GLM-4
exec "$BINARY_PATH" -m glm-4 --provider openai "$@"
